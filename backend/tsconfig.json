{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "moduleResolution": "node",
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"],
  "ts-node": {
    "files": true
  },
  "exclude": ["node_modules"]
}